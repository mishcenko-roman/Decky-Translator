{
  "name": "decky-translator",
  "version": "0.9.0",
  "type": "module",
  "description": "Translate anything on screen to your language. Works with any game or application - a great tool for language learning or enjoying untranslated games",
  "scripts": {
    "build": "shx rm -rf dist && rollup -c",
    "watch": "rollup -c -w",
    "test": "echo \"Error: no test specified\" && exit 1",
    "build:deck": "wsl -e sh -c \"rm -rf out node_modules && ./cli/decky plugin build . -o ./out\""
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cat-in-a-box/decky-translator.git"
  },
  "keywords": [
    "decky",
    "plugin",
    "translation",
    "language-learning",
    "steam-deck",
    "deck"
  ],
  "author": "cat-in-a-box",
  "license": "GNU GPLv3",
  "bugs": {
    "url": "https://github.com/cat-in-a-box/decky-translator/issues"
  },
  "homepage": "https://github.com/cat-in-a-box/decky-translator",
  "devDependencies": {
    "@decky/api": "^1.1.3",
    "@decky/rollup": "^1.0.1",
    "@decky/ui": "^4.11.1",
    "@rollup/rollup-linux-x64-musl": "^4.53.3",
    "@types/react": "19.1.1",
    "@types/react-dom": "^19.1.2",
    "@types/webpack": "^5.28.0",
    "rollup": "^4.53.3",
    "shx": "^0.3.4",
    "tslib": "^2.7.0",
    "typescript": "^5.6.0"
  },
  "dependencies": {
    "qrcode.react": "^4.2.0"
  },
  "pnpm": {
    "peerDependencyRules": {
      "ignoreMissing": [
        "react",
        "react-dom"
      ]
    }
  },
  "remote_binary": [
    {
      "name": "plugin-dependencies.tar.gz",
      "url": "https://github.com/cat-in-a-box/Decky-Translator/releases/download/0.9.0/plugin-dependencies.tar.gz",
      "sha256hash": "ac63b79aba91f6affb1f2a7d3dd1bb821e626b9ef7b76997268f765b8899d6d4"
    }
  ]
}
